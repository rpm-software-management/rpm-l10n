#, c-format
msgid "absolute symlink: %s -> %s\n"
msgstr "symlink ແບບສົມບູນ (absolute): %s -> %s\n"

#: build/files.cc:1257
#, c-format
msgid "Symlink points to BuildRoot: %s -> %s\n"
msgstr "Symlink ຊີ້ໄປທີ່ BuildRoot: %s -> %s\n"

#: build/files.cc:1381
#, c-format
msgid "Illegal character (0x%x) in filename: %s\n"
