#, c-format
msgid "File must begin with \"/\": %s\n"
msgstr "ໄຟລ໌ຕ້ອງເລີ່ມຕົ້ນດ້ວຍ \"/\": %s\n"

#: build/files.cc:1033
#, c-format
msgid ""
"%%clamp_mtime_to_source_date_epoch is deprecated, please use "
"%%build_mtime_policy\n"
msgstr ""
"%%clamp_mtime_to_source_date_epoch ເຊົາໃຊ້ແລ້ວ, ກະລຸນາໃຊ້ %%build_mtime_policy ແທ"
"ນ\n"

#: build/files.cc:1050
#, c-format
msgid "unable to parse %s=%s\n"
msgstr "ບໍ່ສາມາດວິເຄາະ %s=%s ໄດ້\n"

#: build/files.cc:1057
#, c-format
msgid "Unknown mtime policy '%s'\n"
msgstr "ບໍ່ຮູ້ຈັກນະໂຍບາຍ mtime '%s'\n"

#: build/files.cc:1073
#, c-format
msgid "Unknown file digest algorithm %u, falling back to %u\n"
msgstr ""
"ບໍ່ຮູ້ຈັກອັນກໍຣິທຶມສະຫຼຸບໄຟລ໌ (digest algorithm) %u, ກໍາລັງກັບໄປໃຊ້ %u\n"

#: build/files.cc:1125
#, c-format
msgid "File listed twice: %s\n"
msgstr "ໄຟລ໌ຖືກລະບຸໄວ້ສອງຄັ້ງ: %s\n"

#: build/files.cc:1245
#, c-format
msgid "reading symlink %s failed: %s\n"
msgstr "ການອ່ານ symlink %s ຫຼົ້ມເຫຼວ: %s\n"

