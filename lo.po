#: build/build.cc:317
msgid "Failed build dependencies:\n"
msgstr "ການກວດສອບສິ່ງທີ່ຈຳເປັນຕ້ອງມີໃນການສ້າງຫຼົ້ມເຫຼວ:\n"

#: build/build.cc:346
#, c-format
msgid "failed to create package build directory %s: %s\n"
msgstr "ສ້າງໄດເຣັກທໍຣີສ້າງແພັກເກດ %s ບໍ່ສຳເລັດ: %s\n"

#: build/build.cc:387
#, c-format
msgid "setting %s=%s\n"
msgstr "ກຳລັງຕັ້ງຄ່າ %s=%s\n"

#: build/build.cc:391
#, c-format
msgid ""
"%%source_date_epoch_from_changelog is set, but %%changelog has no entries to "
"take a date from\n"
msgstr ""
"%%source_date_epoch_from_changelog ຖືກຕັ້ງຄ່າໄວ້, ແຕ່ %%changelog ບໍ່ມີຂໍ້ມູນທີ່ຈະດຶງວັນທີມາໃຊ້"
"ໄດ້\n"

