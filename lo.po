#: build/build.cc:42
msgid "unable to parse _buildtime macro\n"
msgstr "ບໍ່ສາມາດວິເຄາະມາໂຄຣ _buildtime ໄດ້\n"

#: build/build.cc:50
msgid "unable to parse SOURCE_DATE_EPOCH\n"
msgstr "ບໍ່ສາມາດວິເຄາະ SOURCE_DATE_EPOCH ໄດ້\n"

