#, c-format
msgid "Invalid capability: %s\n"
msgstr "ຄວາມສາມາດ (capability) ບໍ່ຖືກຕ້ອງ: %s\n"

#: build/files.cc:847
msgid "File capability support not built in\n"
msgstr "ບໍ່ໄດ້ຕິດຕັ້ງການຮອງຮັບຄວາມສາມາດຂອງໄຟລ໌ມາພ້ອມ (not built in)\n"

#: build/files.cc:896
#, c-format
msgid "Missing quote: %s\n"
