#: build/files.cc:2597
msgid "Generating build-id links failed\n"
msgstr "ການສ້າງລິ້ງ build-id ຫຼົ້ມເຫຼວ\n"

#: build/files.cc:2702
#, c-format
msgid "Bad file: %s: %s\n"
msgstr "ໄຟລ໌ທີ່ບໍ່ດີ: %s: %s\n"

#: build/files.cc:2759
#, c-format
msgid "Checking for unpackaged file(s): %s\n"
msgstr "ກຳລັງກວດສອບໄຟລ໌ທີ່ບໍ່ໄດ້ຖືກຈັດລົງແພັກເກດ: %s\n"

#: build/files.cc:2772
#, c-format
msgid ""
"Installed (but unpackaged) file(s) found:\n"
"%s"
msgstr ""
"ພົບໄຟລ໌ທີ່ຕິດຕັ້ງແລ້ວ (ແຕ່ບໍ່ໄດ້ຢູ່ໃນແພັກເກດ):\n"
"%s"

#: build/files.cc:2829
#, c-format
msgid "package %s already exists\n"
msgstr "ແພັກເກດ %s ມີຢູ່ແລ້ວ\n"

#: build/files.cc:2892
#, c-format
msgid "%s was mapped to multiple filenames"
msgstr "%s ຖືກຈັບຄູ່ກັບຊື່ໄຟລ໌ຫຼາຍຊື່"

#: build/files.cc:3143
#, c-format
msgid "Processing files: %s\n"
msgstr "ກຳລັງປະມວນຜົນໄຟລ໌: %s\n"

#: build/files.cc:3165
#, c-format
msgid "Binaries arch (%d) not matching the package arch (%d).\n"
msgstr "ສະຖາປັດຕະຍະກຳຂອງໄຟລ໌ໄບນາຣີ (%d) ບໍ່ກົງກັບຂອງແພັກເກດ (%d).\n"

#: build/files.cc:3171
msgid "Arch dependent binaries in noarch package\n"
msgstr "ພົບໄຟລ໌ໄບນາຣີທີ່ຂຶ້ນກັບສະຖາປັດຕະຍະກຳໃນແພັກເກດແບບ noarch\n"

#: build/pack.cc:102
#, c-format
msgid "create archive failed on file %s: %s\n"
msgstr "ການສ້າງບົດຈັດເກັບ (archive) ຫຼົ້ມເຫຼວໃນໄຟລ໌ %s: %s\n"

#: build/pack.cc:105
#, c-format
msgid "create archive failed: %s\n"
msgstr "ການສ້າງບົດຈັດເກັບຫຼົ້ມເຫຼວ: %s\n"

#: build/pack.cc:331
#, c-format
msgid "Unknown payload compression: %s\n"
msgstr "ບໍ່ຮູ້ຈັກການບີບອັດສ່ວນຂໍ້ມູນ (payload compression): %s\n"

#: build/pack.cc:385 sign/rpmgensig.cc:207 sign/rpmgensig.cc:808
#: sign/rpmgensig.cc:847
#, c-format
